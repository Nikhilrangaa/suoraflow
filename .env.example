# PostgreSQL — internal docker-compose hostnames used as defaults
POSTGRES_USER=suoraflow
POSTGRES_PASSWORD=suoraflow_secret
POSTGRES_DB=suoraflow

# Full DSN for SQLModel / psycopg (uses internal "db" hostname)
DATABASE_URL=postgresql+psycopg://suoraflow:suoraflow_secret@db:5432/suoraflow

# Redis (uses internal "redis" hostname)
REDIS_URL=redis://redis:6379/0

# CORS — restrict to the frontend origin; no wildcard allowed
FRONTEND_URL=http://localhost:5173

# Vite — must be the externally-reachable backend URL (used by the browser)
VITE_API_URL=http://localhost:8000

# Storage
STORAGE_ROOT=/storage

# Upload limits
MAX_UPLOAD_MB=500

# Whisper / ASR
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Sentence-transformers embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Hugging Face token (optional) — leave blank to disable diarization
# The pipeline still runs; all segments are labelled "Speaker 1"
HF_TOKEN=
